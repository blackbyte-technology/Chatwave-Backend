        "recipient": "{{senderNumber}}",
        "message_template": "👋 Hi {{contact_name}},\n\nCan I ask you one simple question?\n\n🤔 How many policy renewals do you think you miss every month?\n\nEven missing *2–3 renewals* can cost thousands in commission every year.\n\nInsurance Desk helps you stay on top of every renewal automatically.\n\n👇 Tell us about your business.",
        "interactive_type": "button",
        "button_params": [
          { "title": "😊 Rarely Miss", "id": "___btn_rarely_miss" },
          { "title": "😕 Sometimes Miss", "id": "___btn_sometimes_miss" },
          { "title": "😟 Frequently Miss", "id": "___btn_frequently_miss" }
        ]
