      "parameters": {
        "recipient": "{{senderNumber}}",
        "message_template": "📅 Great choice!\n\nPlease select your preferred time for a live demo:",
        "interactive_type": "button",
        "button_params": [
          { "title": "🌅 Morning", "id": "___btn_demo_morning" },
          { "title": "🌞 Afternoon", "id": "___btn_demo_afternoon" },
          { "title": "🌙 Evening", "id": "___btn_demo_evening" }
