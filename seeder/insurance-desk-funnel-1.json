{
  "name": "Insurance Desk – Funnel 1 (Meta Lead → Trial Activation)",
  "description": "5-day WhatsApp automation funnel for converting Meta ad leads to Insurance Desk trial activations. Includes micro-conversation strategy, lead scoring, interest-based personalization, and urgency-driven CTAs.",
  "is_active": true,
  "triggers": [
    {
      "event_type": "message_received",
      "conditions": {}
    }
  ],
  "nodes": [
    {
      "id": "trigger-meta-lead",
      "type": "trigger",
      "position": { "x": 400, "y": 0 },
      "name": "Meta Lead Entry",
      "description": "Triggered when a lead messages from Meta ad",
      "parameters": {}
    },
    {
      "id": "cond-start-welcome",
      "type": "condition",
      "position": { "x": 400, "y": 100 },
      "name": "Start Condition",
      "description": "Match any incoming message to start funnel",
      "parameters": {
        "condition": {
          "field": "message",
          "operator": "is_not_empty",
          "value": ""
        }
      }
    },
    {
      "id": "tag-meta-lead",
      "type": "add_tag",
      "position": { "x": 400, "y": 200 },
      "name": "Assign META_LEAD Tag",
      "description": "Tag contact as META_LEAD",
      "parameters": {
        "tag_name": "META_LEAD"
      }
    },
    {
      "id": "score-welcome",
      "type": "update_lead_score",
      "position": { "x": 400, "y": 280 },
      "name": "Score: Welcome (+5)",
      "description": "Opened welcome message",
      "parameters": {
        "score_action": "increment",
        "score_value": 5,
        "auto_tag": true
      }
    },
    {
      "id": "msg-welcome",
      "type": "send_message",
      "position": { "x": 400, "y": 360 },
      "name": "Welcome Message",
      "description": "Send welcome message with 3 quick reply buttons",
      "parameters": {
        "recipient": "{{senderNumber}}",
        "message_template": "🎉 Welcome to *Insurance Desk!*\n\nGrow your insurance business with our *30-Day FREE Trial.*\n\n✅ No Credit Card Required\n✅ Full Feature Access\n✅ Free Onboarding Support\n\n🎥 Watch Demo Video\n\n👇 Choose what you'd like to do.",
        "interactive_type": "button",
        "button_params": [
          { "title": "🚀 Start Free Trial", "id": "___btn_start_trial" },
          { "title": "📅 Book Live Demo", "id": "___btn_book_demo" },
          { "title": "⏰ I'll Try Later", "id": "___btn_try_later" }
        ]
      }
    },
    {
      "id": "wait-welcome",
      "type": "wait_for_reply",
      "position": { "x": 400, "y": 460 },
      "name": "Wait for Welcome Reply",
      "description": "Wait for user to click a button",
      "parameters": {
        "variable_name": "welcome_reply"
      }
    },
    {
      "id": "cond-welcome-reply",
      "type": "condition",
      "position": { "x": 400, "y": 540 },
      "name": "Welcome Reply Branch",
      "description": "Branch based on which button was clicked",
      "parameters": {
        "conditions": [
          {
            "id": "cond-start-trial",
            "field": "message",
            "operator": "contains_any",
            "value": ["___btn_start_trial", "Start Free Trial", "start trial"],
            "sourceHandle": "handle-start-trial"
          },
          {
            "id": "cond-book-demo",
            "field": "message",
            "operator": "contains_any",
            "value": ["___btn_book_demo", "Book Live Demo", "book demo"],
            "sourceHandle": "handle-book-demo"
          },
          {
            "id": "cond-try-later",
            "field": "message",
            "operator": "contains_any",
            "value": ["___btn_try_later", "I'll Try Later", "try later"],
            "sourceHandle": "handle-try-later"
          }
        ],
        "no_match_handle": "handle-try-later"
      }
    },

    {
      "id": "tag-trial-started",
      "type": "add_tag",
      "position": { "x": 100, "y": 640 },
      "name": "Tag: TRIAL_STARTED",
      "description": "Mark contact as trial started",
      "parameters": {
        "tag_name": "TRIAL_STARTED"
      }
