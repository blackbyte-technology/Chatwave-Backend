      "id": "score-demo",
      "type": "update_lead_score",
      "position": { "x": 400, "y": 860 },
      "name": "Score: Demo Booked (+40)",
      "description": "Demo booking score",
      "parameters": {
        "score_action": "increment",
        "score_value": 40,
        "auto_tag": true
      }
    },
    {
      "id": "msg-demo-confirm",
      "type": "send_message",
      "position": { "x": 400, "y": 940 },
      "name": "Demo Confirmation",
      "description": "Confirm demo booking",
      "parameters": {
        "recipient": "{{senderNumber}}",
        "message_template": "🎉 Thank you!\n\nYour demo request has been received successfully.\n\nOne of our product experts will connect with you during your selected time slot.\n\nWe look forward to helping you grow your insurance business. 🚀"
      }
